      "isDeleted": false,
      "boundElements": [],
      "updated": 1774459968334,
      "link": null,
      "locked": false,
      "text": "Supabase Auth used to verify that the email is unique before account creation,\n preventing duplicate accounts and abuse of the 50 free coins signup bonus.\n Row Level Security (RLS) enabled on the users table so that a user can only read and modify their own data,\n preventing any client from accessing another user's phone number or personal info.",
      "fontSize": 90,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "Supabase Auth used to verify that the email is unique before account creation,\n preventing duplicate accounts and abuse of the 50 free coins signup bonus.\n Row Level Security (RLS) enabled on the users table so that a user can only read and modify their own data,\n preventing any client from accessing another user's phone number or personal info.",
      "autoResize": true,
      "lineHeight": 1.25
    },
